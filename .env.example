# ─────────────────────────────────────────────────────────────
# PayFast credentials (SERVER-SIDE ONLY — never commit real values)
# ─────────────────────────────────────────────────────────────
# These are consumed by the PHP backend in public/payfast/.
#
# On HostAfrica cPanel the simplest, most reliable approach is to copy
#   public/payfast/config.example.php  ->  public/payfast/config.local.php
# and fill in the same values there (config.local.php is git-ignored and
# blocked from the web). The PHP also reads these environment variables if
# you prefer to set them via cPanel (MultiPHP INI Editor / .htaccess SetEnv).
#
# Use the sandbox values first, then switch to your live credentials and
# set PAYFAST_ENV=live for production.

PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_RETURN_URL=https://selmasi.africa/payment/success/
PAYFAST_CANCEL_URL=https://selmasi.africa/payment/cancelled/
PAYFAST_NOTIFY_URL=https://selmasi.africa/payfast/notify.php
PAYFAST_ENV=sandbox
